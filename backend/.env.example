# PostgreSQL connection string
# Railway: Use ${{Postgres.DATABASE_URL}} reference in Railway Variables tab
# Local: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Anthropic key for the agent chat feature
ANTHROPIC_API_KEY=sk-ant-...

# Optional: directory for Claude Code CLI session cwd (default: /tmp/staffing-claude-agent).
# Must be writable; a git repo is created automatically if `git` is on PATH.
# AGENT_WORKSPACE_DIR=/tmp/staffing-claude-agent

# Optional: per-dynamic-tool Python venvs for agent-authored code (default: backend/.sandbox-envs).
# SANDBOX_ENVS_DIR=/app/.sandbox-envs

# Secret key used to sign JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-random-secret

# Optional: auto-create an admin account on first startup.
# If set and the username doesn't exist yet, the user is created with role=admin.
# Leave unset to use the "first registered user becomes admin" behaviour instead.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
