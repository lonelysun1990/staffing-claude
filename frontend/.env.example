# URL of the deployed backend service (no trailing slash)
# Railway: Set this BEFORE deploying so it's embedded at build time
# Example: https://backend-production-8c04.up.railway.app
VITE_API_BASE_URL=https://your-backend.railway.app

# Allowed host for the preview server (just the hostname, no https://)
# Railway: Set this to your frontend domain
# Example: frontend-production-ae99.up.railway.app
VITE_ALLOWED_HOST=your-frontend.up.railway.app
